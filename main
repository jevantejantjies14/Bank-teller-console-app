//STRUCT BRANCHES and other details for question

struct Branch {
    char code[10];
    char name[50];
    char address[100];
    char manager[50];
};

struct Teller {
    char id[10];
    char fullName[50];
    char password[50]; // will be encrypted later
    char branchCode[10];
};
// accounts - picking up from last left off
struct Account {
    char accountNumber[20];
    char firstName[10];
    char surname[50];
    char idNumber[100];
    char contact[50];
    char email[10];
    char address[50];
    char dob[50];
    int type; //the accounts type, dont forget!
    double balance;
    char branchCode[10];
    char pin[10]; //encryoted
    bool locked;
    int faledAttempts;
};

struct Transaction {
    char txnID[15];
    char accountNumber[25];
    int type;
    double amount;
    double balanceBefore;
    double balanceAfter;
    char dateTime[25];
    char targetAccount[25];
    char branchCode[10];
    char processedBy[10];
};
