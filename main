// report menus for all previously created functions
void reportMenu(){
    int ch;
    do {
        printHeader("REPORTS MENU");
        cout << "1. Daily Transaction Reports\n";
        cout << "2. Customer Account Summary\n";
        cout << "3. Branch Performance Report\n";
        cout << "4. Export to CSV \n";
        cout << "5. BAckup Data\n";
        cout << "0. Back button\n";
        switch (ch) {
            case 1:
                dailyTransactionReport();
                break;
            case 2: 
                customerAccountSummary();
                break;
            case 3:
                branchPerformanceReport();
                break;
            case 4:
                exportToCSV();
                break;
            case 5: 
                backupData();
                break;
        }
    }   while (ch != 0);
    void tellerTransactionMenu(){
        char accNum[25];
        cout << "Enter Customer Account Number: "; 
        cin >> accNum;

        int idx = -1;
        for (int i = 0; i < customerCount; i++)
            if (strcmp(customers[i].accNum, accNum) == 0) {idx = i;break;}
        if (idx == -1 ) { cout << "Account not found. " << endl; return;}

        cout << "Customer: " << customers[idx].fname << " " << customers[idx].sname << endl;
        if (!verifyPINForAccount(idx)) {
            cout << "PIN verification failed. " << endl;
            return;
        }
        int ch;
        do {
            cout << "\n 1. Deposit \n2. Withdrawal \n3. Transfer \n 4. View Statement \n0. Back\nChoice:";
            cin >> ch;
            switch (ch){
                case 1:
                    processDeposit(idx);
                    break;
                case 2:
                    processWithdrawal(idx);
                    break;
                case 3:
                    processTransfer(idx);
                    break;
                case 4:
                    viewStatement(idx);
                    break;

            }
        }

    } 
}
