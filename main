        Branch b3; strcpy(b3.code, "DBN"); strcpy(b3.name, "Durban North");
        strcpy(b3.address, "789 Beach Rd, DBN"); strcpy(b3.manager, "Raj Naidoo");
        branches[branchCount++] = b3; saveBranch(b3);
    }

    // Create default tellers
    if (!fileExists("tellers.dat")) {
        Teller t1; strcpy(t1.id, "T001"); strcpy(t1.fullName, "John Smith");
        strcpy(t1.password, "admin123"); strcpy(t1.branchCode, "JHB");
        encrypt(t1.password, strlen(t1.password));
        tellers[tellerCount++] = t1; saveTeller(t1);

        Teller t2; strcpy(t2.id, "T002"); strcpy(t2.fullName, "Sarah Jones");
        strcpy(t2.password, "teller456"); strcpy(t2.branchCode, "CPT");
        encrypt(t2.password, strlen(t2.password));
        tellers[tellerCount++] = t2; saveTeller(t2);

        Teller t3; strcpy(t3.id, "T003"); strcpy(t3.fullName, "Thabo Mokoena");
        strcpy(t3.password, "pass789"); strcpy(t3.branchCode, "DBN");
        encrypt(t3.password, strlen(t3.password));
        tellers[tellerCount++] = t3; saveTeller(t3);
    }

