void backupData() {
    // Simple backup: copy contents to backup files
    auto copyFile = [](const char* src, const char* dst) {
        ifstream in(src, ios::binary);
        ofstream out(dst, ios::binary);
        if (in && out) out << in.rdbuf();
    };
    copyFile("customers.dat",    "customers_backup.dat");
    copyFile("tellers.dat",      "tellers_backup.dat");
    copyFile("transactions.dat", "transactions_backup.dat");
    copyFile("branches.dat",     "branches_backup.dat");
    cout << "Backup completed successfully." << endl;
}

void exportToCSV() {
    ofstream f("report_export.csv");
    f << "AccountNumber,FirstName,Surname,Type,Balance,Branch,Locked\n";
    for (int i = 0; i < customerCount; i++) {
        f << customers[i].accountNumber << ","
          << customers[i].firstName << ","
          << customers[i].surname << ","
          << getTypeName(customers[i].type) << ","
          << fixed << setprecision(2) << customers[i].balance << ","
          << customers[i].branchCode << ","
          << (customers[i].locked ? "Yes" : "No") << "\n";
    }
    f.close();
    cout << "Exported to report_export.csv" << endl;
}
//authentication
bool tellerLogin() {
    printHeader("TELLER LOGIN");
    char id[10], pass[50];
    cout << "Teller ID   : "; cin >> id;
    cout << "Password    : "; cin >> pass;

    char encPass[50];
    strcpy(encPass, pass);
    encrypt(encPass, strlen(encPass));

    for (int i = 0; i < tellerCount; i++) {
        if (strcmp(tellers[i].id, id) == 0 &&
            strcmp(tellers[i].pass, encPass) == 0) {
            currentTeller = tellers[i];
            tellerLoggedIn = true;
            cout << "\nWelcome, " << currentTeller.full_name
                 << " [Branch: " << currentTeller.brCode << "]" << endl;
            return true;
        }
    }
    cout << "Invalid Teller ID or Password." << endl;
    return false;
}

bool customerLogin() {
    printHeader("CUSTOMER LOGIN");
    char accNum[25];
    cout << "Account Number : "; cin >> accNum;

    int idx = -1;
    for (int i = 0; i < customerCount; i++) {
        if (strcmp(customers[i].accNum, accNum) == 0) {
            idx = i; break;
        }
    }

    if (idx == -1) { cout << "Account not found." << endl; return false; }

    if (customers[idx].locked) {
        cout << "Account is locked. Please visit your branch." << endl;
        return false;
    }

    int attempts = 0;
    while (attempts < 3) {
        char pin[10];
        cout << "PIN : "; cin >> pin;

        char encPin[10];
        strcpy(encPin, pin);
        encrypt(encPin, strlen(encPin));

        if (strcmp(customers[idx].pin, encPin) == 0) {
            customers[idx].failCount = 0;
            saveAllCustomers();
            currentCustomer = customers[idx];
            customerLoggedIn = true;
            cout << "\nWelcome, " << currentCustomer.fname << "!" << endl;
            return true;
        }

        attempts++;
        customers[idx].failCount++;
        if (customers[idx].failCount >= 3) {
            customers[idx].locked = true;
            saveAllCustomers();
            cout << "Too many failed attempts. Account locked." << endl;
            return false;
        }
        cout << "Wrong PIN. " << (3 - attempts) << " attempt(s) remaining." << endl;
    }
    return false;
}

// ACCOUNT MANAGEMENT
void registerCustomer() {
    if (!tellerLoggedIn) { cout << "Access denied." << endl; return; }
    printHeader("REGISTER NEW CUSTOMER");

    Account a;
    memset(&a, 0, sizeof(Account));

    cout << "First Name   : "; cin >> a.fname;
    cout << "Surname      : "; cin >> a.sname;

    do {
        cout << "SA ID Number (13 digits): "; cin >> a.saID;
        if (!validateID(a.saID)) cout << "Invalid ID. Must be 13 digits." << endl;
    } while (!validateID(a.saID));

    do {
        cout << "Contact Number (10 digits): "; cin >> a.cell;
        if (!validateContact(a.cell)) cout << "Invalid. Must be 10 digits starting with 0." << endl;
    } while (!validateContact(a.cell));

    do {
        cout << "Email Address: "; cin >> a.email;
        if (!validateEmail(a.email)) cout << "Invalid email format." << endl;
    } while (!validateEmail(a.email));

    cin.ignore();
    cout << "Physical Address: "; cin.getline(a.addr, 100);

    cout << "Date of Birth (DD/MM/YYYY): "; cin >> a.dob;

    cout << "\nAccount Type:\n";
    cout << "1. Savings (min R500)\n";
    cout << "2. Cheque (min R1000)\n";
    cout << "3. Fixed Deposit (min R10000)\n";
    cout << "4. Student (min R50)\n";
    cout << "Choice: "; int tc; cin >> tc;
    a.accType = tc - 1;

    double minDep = getMinDeposit(a.accType);
    do {
        cout << "Initial Deposit (min R" << fixed << setprecision(2) << minDep << "): ";
        cin >> a.balance;
        if (a.balance < minDep)
            cout << "Amount too low. Minimum is R" << minDep << endl;
    } while (a.balance < minDep);

    string accNum = generateAccountNumber(currentTeller.brCode);
    strcpy(a.accNum, accNum.c_str());
    strcpy(a.brCode, currentTeller.brCode);

    int pinInt = generatePIN();
    char pinStr[10];
    sprintf(pinStr, "%d", pinInt);
    char encPin[10];
    strcpy(encPin, pinStr);
    encrypt(encPin, strlen(encPin));
    strcpy(a.pin, encPin);

    a.locked = false;
    a.failCount = 0;

    customers[customerCount++] = a;
    saveCustomer(a);

    Transaction t;
    memset(&t, 0, sizeof(Transaction));
    string txnID = generateTxnID();
    strcpy(t.txnID, txnID.c_str());
    strcpy(t.accNum, a.accNum);
    t.transType = DEPOSIT;
    t.amount = a.balance;
    t.balBefore = 0;
    t.balAfter = a.balance;
    string dt = getCurrentDateTime();
    strcpy(t.dt, dt.c_str());
    strcpy(t.brCode, a.brCode);
    strcpy(t.processedBy, currentTeller.id);
    saveTransaction(t);

    cout << "\n--- ACCOUNT CREATED SUCCESSFULLY ---" << endl;
    cout << "Account Number : " << a.accNum << endl;
    cout << "Customer PIN   : " << pinStr << " (Show to customer once only!)" << endl;
    printLine();
}

void viewCustomerDetails() {
    printHeader("VIEW CUSTOMER DETAILS");
    char accNum[25];
    cout << "Enter Account Number: "; cin >> accNum;

    for (int i = 0; i < customerCount; i++) {
        if (strcmp(customers[i].accNum, accNum) == 0) {
            printLine('-');
            cout << "Account Number : " << customers[i].accNum << endl;
            cout << "Name           : " << customers[i].fname << " " << customers[i].sname << endl;
            cout << "ID Number      : " << customers[i].saID << endl;
            cout << "Contact        : " << customers[i].cell << endl;
            cout << "Email          : " << customers[i].email << endl;
            cout << "Address        : " << customers[i].addr << endl;
            cout << "Date of Birth  : " << customers[i].dob << endl;
            cout << "Account Type   : " << getTypeName(customers[i].accType) << endl;
            cout << "Balance        : R" << fixed << setprecision(2) << customers[i].balance << endl;
            cout << "Branch         : " << customers[i].brCode << endl;
            cout << "Status         : " << (customers[i].locked ? "LOCKED" : "Active") << endl;
            printLine('-');
            return;
        }
    }
    cout << "Customer not found." << endl;
}

void searchCustomer() {
    printHeader("SEARCH CUSTOMER");
    cout << "1. Search by Account Number\n";
    cout << "2. Search by Name\n";
    cout << "3. Search by ID Number\n";
    cout << "4. Search by Branch\n";
    cout << "Choice: "; int ch; cin >> ch;

    char term[50];
    bool found = false;

    if (ch == 1) {
        cout << "Account Number: "; cin >> term;
        for (int i = 0; i < customerCount; i++)
            if (strcmp(customers[i].accNum, term) == 0) {
                cout << customers[i].accNum << " | "
                     << customers[i].fname << " " << customers[i].sname
                     << " | R" << fixed << setprecision(2) << customers[i].balance << endl;
                found = true;
            }
    } else if (ch == 2) {
        cout << "Name (partial): "; cin >> term;
        for (int i = 0; i < customerCount; i++) {
            char fullName[61];
            strcpy(fullName, customers[i].fname);
            strcat(fullName, " ");
            strcat(fullName, customers[i].sname);
            if (strstr(fullName, term)) {
                cout << customers[i].accNum << " | "
                     << fullName << " | " << getTypeName(customers[i].accType) << endl;
                found = true;
            }
        }
    } else if (ch == 3) {
        cout << "ID Number: "; cin >> term;
        for (int i = 0; i < customerCount; i++)
            if (strcmp(customers[i].saID, term) == 0) {
                cout << customers[i].accNum << " | "
                     << customers[i].fname << " " << customers[i].sname << endl;
                found = true;
            }
    } else if (ch == 4) {
        cout << "Branch Code: "; cin >> term;
        for (int i = 0; i < customerCount; i++)
            if (strcmp(customers[i].brCode, term) == 0) {
                cout << customers[i].accNum << " | "
                     << customers[i].fname << " " << customers[i].sname
                     << " | R" << fixed << setprecision(2) << customers[i].balance << endl;
                found = true;
            }
    }

    if (!found) cout << "No results found." << endl;
}

// TRANSACTION STUFF
bool verifyPINForAccount(int idx) {
    char pin[10];
    cout << "Enter PIN: "; cin >> pin;
    char encPin[10];
    strcpy(encPin, pin);
    encrypt(encPin, strlen(encPin));
    return strcmp(customers[idx].pin, encPin) == 0;
}

void recordTransaction(int idx, int type, double amount, const char* target = "") {
    Transaction t;
    memset(&t, 0, sizeof(Transaction));
    string txnID = generateTxnID();
    strcpy(t.txnID, txnID.c_str());
    strcpy(t.accNum, customers[idx].accNum);
    t.transType = type;
    t.amount = amount;
    t.balBefore = customers[idx].balance - (type == DEPOSIT ? amount : -amount);
    t.balAfter = customers[idx].balance;
    string dt = getCurrentDateTime();
    strcpy(t.dt, dt.c_str());
    strcpy(t.brCode, customers[idx].brCode);
    strcpy(t.targetAcc, target);
    if (tellerLoggedIn)
        strcpy(t.processedBy, currentTeller.id);
    else
        strcpy(t.processedBy, "SELF");
    saveTransaction(t);
}

void processDeposit(int idx) {
    try {
        printHeader("CASH DEPOSIT");
        double amount;
        cout << "Deposit Amount: R"; cin >> amount;
        if (amount <= 0) throw runtime_error("Amount must be greater than zero.");

        customers[idx].balance += amount;
        saveAllCustomers();
        recordTransaction(idx, DEPOSIT, amount);

        cout << "\nDeposit Successful!" << endl;
        cout << "Amount Deposited : R" << fixed << setprecision(2) << amount << endl;
        cout << "New Balance      : R" << fixed << setprecision(2) << customers[idx].balance << endl;

    } catch (runtime_error& e) {
        cout << "Error: " << e.what() << endl;
    }
}

void processWithdrawal(int idx) {
    try {
        if (customers[idx].accType == FIXED)
            throw runtime_error("Withdrawals not allowed on Fixed Deposit accounts.");

        printHeader("CASH WITHDRAWAL");
        double amount;
        cout << "Withdrawal Amount: R"; cin >> amount;
        if (amount <= 0) throw runtime_error("Amount must be greater than zero.");

        double overdraft = (customers[idx].accType == CHEQUE) ? 500.0 : 0.0;
        if (amount > customers[idx].balance + overdraft)
            throw runtime_error("Insufficient funds.");

        customers[idx].balance -= amount;
        saveAllCustomers();
        recordTransaction(idx, WITHDRAWAL, amount);

        cout << "\nWithdrawal Successful!" << endl;
        cout << "Amount Withdrawn : R" << fixed << setprecision(2) << amount << endl;
        cout << "New Balance      : R" << fixed << setprecision(2) << customers[idx].balance << endl;

    } catch (runtime_error& e) {
        cout << "Error: " << e.what() << endl;
    }
}

void processTransfer(int idx) {
    try {
        printHeader("FUND TRANSFER");
        char targetAcc[25];
        cout << "Target Account Number: "; cin >> targetAcc;

        int targetIdx = -1;
        for (int i = 0; i < customerCount; i++)
            if (strcmp(customers[i].accNum, targetAcc) == 0) { targetIdx = i; break; }

        if (targetIdx == -1) throw runtime_error("Target account not found.");
        if (targetIdx == idx) throw runtime_error("Cannot transfer to the same account.");

        double amount;
        cout << "Transfer Amount: R"; cin >> amount;
        if (amount <= 0) throw runtime_error("Amount must be greater than zero.");
        if (amount > customers[idx].balance) throw runtime_error("Insufficient funds.");

        customers[idx].balance -= amount;
        customers[targetIdx].balance += amount;
        saveAllCustomers();

        recordTransaction(idx, TRANSFER, amount, targetAcc);

        Transaction t;
        memset(&t, 0, sizeof(Transaction));
        string txnID = generateTxnID();
        strcpy(t.txnID, txnID.c_str());
        strcpy(t.accNum, customers[targetIdx].accNum);
        t.transType = DEPOSIT;
        t.amount = amount;
        t.balBefore = customers[targetIdx].balance - amount;
        t.balAfter = customers[targetIdx].balance;
        string dt = getCurrentDateTime();
        strcpy(t.dt, dt.c_str());
        strcpy(t.brCode, customers[targetIdx].brCode);
        strcpy(t.targetAcc, customers[idx].accNum);
        strcpy(t.processedBy, tellerLoggedIn ? currentTeller.id : "SELF");
        saveTransaction(t);

        cout << "\nTransfer Successful!" << endl;
        cout << "Transferred      : R" << fixed << setprecision(2) << amount << endl;
        cout << "To Account       : " << targetAcc << endl;
        cout << "Your New Balance : R" << fixed << setprecision(2) << customers[idx].balance << endl;

    } catch (runtime_error& e) {
        cout << "Error: " << e.what() << endl;
    }
}

void viewStatement(const char* accNum) {
    printHeader("ACCOUNT STATEMENT");
    cout << "Account: " << accNum << endl;
    printLine('-');
    cout << left << setw(12) << "TXN ID"
         << setw(22) << "Date & Time"
         << setw(12) << "Type"
         << setw(12) << "Amount"
         << setw(12) << "Balance" << endl;
    printLine('-');

    bool found = false;
    for (int i = 0; i < transactionCount; i++) {
        if (strcmp(transactions[i].accNum, accNum) == 0) {
            cout << left << setw(12) << transactions[i].txnID
                 << setw(22) << transactions[i].dt
                 << setw(12) << getTxnTypeName(transactions[i].transType)
                 << "R" << setw(11) << fixed << setprecision(2) << transactions[i].amount
                 << "R" << setw(11) << fixed << setprecision(2) << transactions[i].balAfter << endl;
            found = true;
        }
    }

    if (!found) cout << "No transactions found for this account." << endl;
    printLine('-');
}

void changePIN(int idx) {
    printHeader("CHANGE PIN");
    cout << "Enter current PIN: ";
    char oldPin[10]; cin >> oldPin;
    char encOld[10]; strcpy(encOld, oldPin); encrypt(encOld, strlen(encOld));

    if (strcmp(customers[idx].pin, encOld) != 0) {
        cout << "Incorrect current PIN." << endl; return;
    }

    char newPin[10], confirmPin[10];
    cout << "Enter new PIN (5 digits): "; cin >> newPin;
    if (!validatePIN(newPin)) { cout << "Invalid PIN format." << endl; return; }

    cout << "Confirm new PIN: "; cin >> confirmPin;
    if (strcmp(newPin, confirmPin) != 0) { cout << "PINs do not match." << endl; return; }

    char encNew[10]; strcpy(encNew, newPin); encrypt(encNew, strlen(encNew));
    strcpy(customers[idx].pin, encNew);
    strcpy(currentCustomer.pin, encNew);
    saveAllCustomers();
    cout << "PIN changed successfully!" << endl;
}

// BRANCH FUNCTIONS
void viewAllBranches() {
    printHeader("ALL BRANCHES");
    cout << left << setw(10) << "Code"
         << setw(25) << "Name"
         << setw(20) << "Manager"
         << "Address" << endl;
    printLine('-');
    for (int i = 0; i < branchCount; i++) {
        cout << left << setw(10) << branches[i].code
             << setw(25) << branches[i].name
             << setw(20) << branches[i].manager
             << branches[i].address << endl;
    }
}

void viewBranchDetails(const char* code) {
    printHeader("BRANCH DETAILS");
    for (int i = 0; i < branchCount; i++) {
        if (strcmp(branches[i].code, code) == 0) {
            cout << "Code    : " << branches[i].code << endl;
            cout << "Name    : " << branches[i].name << endl;
            cout << "Manager : " << branches[i].manager << endl;
            cout << "Address : " << branches[i].address << endl;

            int custCount = 0; double totalBal = 0;
            for (int j = 0; j < customerCount; j++)
                if (strcmp(customers[j].brCode, code) == 0) {
                    custCount++; totalBal += customers[j].balance;
                }
            cout << "Customers     : " << custCount << endl;
            cout << "Total Balance : R" << fixed << setprecision(2) << totalBal << endl;
            return;
        }
    }
    cout << "Branch not found." << endl;
}

void compareBranches() {
    printHeader("BRANCH COMPARISON");
    cout << left << setw(8) << "Code"
         << setw(22) << "Name"
         << setw(12) << "Customers"
         << setw(18) << "Total Balance"
         << "Transactions" << endl;
    printLine('-');

    for (int i = 0; i < branchCount; i++) {
        int cust = 0, txns = 0; double total = 0;
        for (int j = 0; j < customerCount; j++)
            if (strcmp(customers[j].brCode, branches[i].code) == 0) {
                cust++; total += customers[j].balance;
            }
        for (int j = 0; j < transactionCount; j++)
            if (strcmp(transactions[j].brCode, branches[i].code) == 0) txns++;

        cout << left << setw(8) << branches[i].code
             << setw(22) << branches[i].name
             << setw(12) << cust
             << "R" << setw(17) << fixed << setprecision(2) << total
             << txns << endl;
    }
}

// REPORT FUNCTIONS
void dailyTransactionReport() {
    printHeader("DAILY TRANSACTION REPORT");
    string today = getTodayDate();
    cout << "Date: " << today << endl;
    printLine('-');
    cout << left << setw(12) << "TXN ID"
         << setw(25) << "Account"
         << setw(12) << "Type"
         << "Amount" << endl;
    printLine('-');

    double totalDep = 0, totalWith = 0;
    bool found = false;
    for (int i = 0; i < transactionCount; i++) {
        if (strncmp(transactions[i].dt, today.c_str(), 10) == 0) {
            cout << left << setw(12) << transactions[i].txnID
                 << setw(25) << transactions[i].accNum
                 << setw(12) << getTxnTypeName(transactions[i].transType)
                 << "R" << fixed << setprecision(2) << transactions[i].amount << endl;
            if (transactions[i].transType == DEPOSIT)    totalDep  += transactions[i].amount;
            if (transactions[i].transType == WITHDRAWAL) totalWith += transactions[i].amount;
            found = true;
        }
    }
    if (!found) cout << "No transactions today." << endl;
    printLine('-');
    cout << "Total Deposits    : R" << fixed << setprecision(2) << totalDep << endl;
    cout << "Total Withdrawals : R" << fixed << setprecision(2) << totalWith << endl;
    cout << "Net               : R" << fixed << setprecision(2) << (totalDep - totalWith) << endl;
}

void customerAccountSummary() {
    printHeader("CUSTOMER ACCOUNT SUMMARY");
    cout << left << setw(20) << "Account"
         << setw(25) << "Name"
         << setw(15) << "Type"
         << setw(14) << "Balance"
         << "Branch" << endl;
    printLine('-');

    double grandTotal = 0; int count = 0;
    for (int i = 0; i < customerCount; i++) {
        if (tellerLoggedIn && strcmp(customers[i].brCode, currentTeller.brCode) != 0)
            continue;
        cout << left << setw(20) << customers[i].accNum
             << setw(25) << (string(customers[i].fname) + " " + customers[i].sname)
             << setw(15) << getTypeName(customers[i].accType)
             << "R" << setw(13) << fixed << setprecision(2) << customers[i].balance
             << customers[i].brCode << endl;
        grandTotal += customers[i].balance;
        count++;
    }
    printLine('-');
    cout << "Total Customers : " << count << endl;
    cout << "Total Balance   : R" << fixed << setprecision(2) << grandTotal << endl;
}

void branchPerformanceReport() {
    printHeader("BRANCH PERFORMANCE REPORT");
    compareBranches();
}

void applyInterest() {
    if (!tellerLoggedIn) { cout << "Access denied." << endl; return; }
    printHeader("APPLY INTEREST");
    char confirm;
    cout << "Apply interest to all eligible accounts? (y/n): "; cin >> confirm;
    if (confirm != 'y' && confirm != 'Y') return;

    for (int i = 0; i < customerCount; i++) {
        double rate = getInterestRate(customers[i].accType);
        double interest = customers[i].balance * rate;
        cout << customers[i].accNum << " | Balance: R"
             << fixed << setprecision(2) << customers[i].balance
             << " | Interest: R" << interest << endl;
        customers[i].balance += interest;

        Transaction t; memset(&t, 0, sizeof(Transaction));
        string txnID = generateTxnID();
        strcpy(t.txnID, txnID.c_str());
        strcpy(t.accNum, customers[i].accNum);
        t.transType = DEPOSIT; t.amount = interest;
        t.balBefore = customers[i].balance - interest;
        t.balAfter = customers[i].balance;
        string dt = getCurrentDateTime(); strcpy(t.dt, dt.c_str());
        strcpy(t.brCode, customers[i].brCode);
        strcpy(t.processedBy, currentTeller.id);
        saveTransaction(t);
    }
    saveAllCustomers();
    cout << "Interest applied successfully." << endl;
}


