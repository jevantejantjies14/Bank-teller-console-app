// now onto utility functions
// normal code now! 
// encryption now using a for loop to iterate
void encrypt(char* text, int len) {
    for (int i = 0; i < len; i++)
        if (text[i] != '\0') text[i] ^= EKEY;
}

string getCurrentDateTime() {
    time_t now = time(0);
    char buf[25];
    strftime(buf, sizeof(buf), "%d/%m/%Y %H:%M:%S", localtime(&now));
    return string(buf);
}

string getTodayDate() {
    time_t now = time(0);
    char buf[11];
    strftime(buf, sizeof(buf), "%d/%m/%Y", localtime(&now));
    return string(buf);
}

string generateAccountNumber(const char* branchCode) {
    int count = 0;
    for (int i = 0; i < customerCount; i++)
        if (strcmp(customers[i].branchCode, branchCode) == 0) count++;
    count++;
    stringstream ss;
    ss << "ACC-" << branchCode << "-" << setfill('0') << setw(5) << count;
    return ss.str();
}

string generateTxnID() {
    stringstream ss;
    ss << "TXN" << setfill('0') << setw(6) << (transactionCount + 1);
    return ss.str();
}

int generatePIN() {
    return rand() % 90000 + 10000; // 10000-99999
}

double getMinDeposit(int type) {
    switch (type) {
        case SAVINGS: return 500.0;
        case CHEQUE:  return 1000.0;
        case FIXED:   return 10000.0;
        case STUDENT: return 50.0;
        default:      return 0.0;
    }
}

double getInterestRate(int type) {
    switch (type) {
        case SAVINGS: return 0.0525;
        case CHEQUE:  return 0.015;
        case FIXED:   return 0.08;
        case STUDENT: return 0.03;
        default:      return 0.0;
    }
}

string getTypeName(int type) {
    switch (type) {
        case SAVINGS: return "Savings";
        case CHEQUE:  return "Cheque";
        case FIXED:   return "Fixed Deposit";
        case STUDENT: return "Student";
        default:      return "Unknown";
    }
}

string getTxnTypeName(int type) {
    switch (type) {
        case DEPOSIT:    return "Deposit";
        case WITHDRAWAL: return "Withdrawal";
        case TRANSFER:   return "Transfer";
        default:         return "Unknown";
    }
}

bool validateID(const char* id) {
    if (strlen(id) != 13) return false;
    for (int i = 0; i < 13; i++)
        if (!isdigit(id[i])) return false;
    return true;
}

bool validateContact(const char* c) {
    if (strlen(c) != 10) return false;
    if (c[0] != '0') return false;
    for (int i = 0; i < 10; i++)
        if (!isdigit(c[i])) return false;
    return true;
}

bool validateEmail(const char* email) {
    const char* at = strchr(email, '@');
    if (!at) return false;
    const char* dot = strchr(at, '.');
    return dot != nullptr;
}

bool validatePIN(const char* pin) {
    if (strlen(pin) != 5) return false;
    for (int i = 0; i < 5; i++)
        if (!isdigit(pin[i])) return false;
    return true;
}

void printLine(char c = '=', int width = 55) {
    for (int i = 0; i < width; i++) cout << c;
    cout << endl;
}

void printHeader(const string& title) {
    printLine();
    int padding = (55 - title.length()) / 2;
    cout << setw(padding + title.length()) << title << endl;
    printLine();
}
//the file I/O operations for bank tellers

bool fileExists(const char* filename) {
    ifstream f(filename, ios::binary);
    return f.good();
}

void loadBranches() {
    ifstream f("branches.dat", ios::binary);
    if (!f) return;
    while (f.read(reinterpret_cast<char*>(&branches[branchCount]), sizeof(Branch)))
        branchCount++;
}

bool fileExists(const char* filename) {
    ifstream f(filename, ios::binary);
    return f.good();
}

void loadBranches() {
    ifstream f("branches.dat", ios::binary);
    if (!f) return;
    while (f.read(reinterpret_cast<char*>(&branches[branchCount]), sizeof(Branch)))
        branchCount++;
    f.close();
}

void saveBranch(Branch& b) {
    ofstream f("branches.dat", ios::binary | ios::app);
    f.write(reinterpret_cast<char*>(&b), sizeof(Branch));
    f.close();
}

void saveAllBranches() {
    ofstream f("branches.dat", ios::binary | ios::trunc);
    for (int i = 0; i < branchCount; i++)
        f.write(reinterpret_cast<char*>(&branches[i]), sizeof(Branch));
    f.close();
}

void loadTellers() {
    ifstream f("tellers.dat", ios::binary);
    if (!f) return;
    while (f.read(reinterpret_cast<char*>(&tellers[tellerCount]), sizeof(Teller)))
        tellerCount++;
    f.close();
}

void saveTeller(Teller& t) {
    ofstream f("tellers.dat", ios::binary | ios::app);
    f.write(reinterpret_cast<char*>(&t), sizeof(Teller));
    f.close();
}

void loadCustomers() {
    ifstream f("customers.dat", ios::binary);
    if (!f) return;
    while (f.read(reinterpret_cast<char*>(&customers[customerCount]), sizeof(Account)))
        customerCount++;
    f.close();
}

void saveCustomer(Account& a) {
    ofstream f("customers.dat", ios::binary | ios::app);
    f.write(reinterpret_cast<char*>(&a), sizeof(Account));
    f.close();
}

void saveAllCustomers() {
    ofstream f("customers.dat", ios::binary | ios::trunc);
    for (int i = 0; i < customerCount; i++)
        f.write(reinterpret_cast<char*>(&customers[i]), sizeof(Account));
    f.close();
}

void loadTransactions() {
    ifstream f("transactions.dat", ios::binary);
    if (!f) return;
    while (f.read(reinterpret_cast<char*>(&transactions[transactionCount]), sizeof(Transaction)))
        transactionCount++;
    f.close();
}

void saveTransaction(Transaction& t) {
    ofstream f("transactions.dat", ios::binary | ios::app);
    f.write(reinterpret_cast<char*>(&t), sizeof(Transaction));
    f.close();
    transactions[transactionCount++] = t;
}

void loadAllData() {
    loadBranches();
    loadTellers();
    loadCustomers();
    loadTransactions();
}

